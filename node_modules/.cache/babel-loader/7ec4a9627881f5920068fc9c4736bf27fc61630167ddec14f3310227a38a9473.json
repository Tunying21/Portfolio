{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"HomeView\",\n  data() {\n    return {\n      scrolled: false,\n      activeFilter: \"ALL\",\n      activeFilterIndex: 0,\n      form: {\n        name: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      },\n      filterTabs: [\"ALL\", \"CODED\", \"DESIGNED\"],\n      usingNow: [{\n        name: \"HTML5\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg\"\n      }, {\n        name: \"CSS3\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg\"\n      }, {\n        name: \"SASS\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sass/sass-original.svg\"\n      }, {\n        name: \"JAVASCRIPT\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg\"\n      }, {\n        name: \"REACT\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg\"\n      }, {\n        name: \"BOOTSTRAP\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg\"\n      }, {\n        name: \"GIT\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg\"\n      }, {\n        name: \"FIGMA\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg\"\n      }],\n      learning: [{\n        name: \"NODEJS\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg\"\n      }, {\n        name: \"MySQL\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg\"\n      }, {\n        name: \"MONGODB\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg\"\n      }, {\n        name: \"TYPESCRIPT\",\n        icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg\"\n      }],\n      projects: [{\n        image: \"/assets/project-1.jpg\",\n        type: \"DESIGNED\"\n      }, {\n        image: \"/assets/project-3.jpg\",\n        type: \"CODED\",\n        featured: true,\n        name: \"eatsome.\",\n        description: \"Restaurant browsing in React.js (Using Yelp API)\"\n      }, {\n        image: \"/assets/project-2.jpg\",\n        type: \"DESIGNED\"\n      }, {\n        image: \"/assets/project-1.jpg\",\n        type: \"CODED\"\n      }, {\n        image: \"/assets/project-2.jpg\",\n        type: \"DESIGNED\"\n      }, {\n        image: \"/assets/project-1.jpg\",\n        type: \"CODED\"\n      }]\n    };\n  },\n  computed: {\n    filteredProjects() {\n      if (this.activeFilter === \"ALL\") return this.projects;\n      return this.projects.filter(p => p.type === this.activeFilter);\n    },\n    filterUnderlineStyle() {\n      const tabWidth = 149;\n      const startOffset = (587 - tabWidth * 3) / 2;\n      return {\n        width: `${tabWidth}px`,\n        left: `calc(50% - 293px + ${startOffset + this.activeFilterIndex * tabWidth}px)`\n      };\n    }\n  },\n  mounted() {\n    window.addEventListener(\"scroll\", this.handleScroll);\n    this.setupSmoothScroll();\n  },\n  beforeUnmount() {\n    window.removeEventListener(\"scroll\", this.handleScroll);\n  },\n  methods: {\n    handleScroll() {\n      this.scrolled = window.scrollY > 400;\n    },\n    setFilter(tab, index) {\n      this.activeFilter = tab;\n      this.activeFilterIndex = index;\n    },\n    handleSubmit() {\n      alert(\"Thank you for your message! I will get back to you soon.\");\n      this.form = {\n        name: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\"\n      };\n    },\n    setupSmoothScroll() {\n      document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n        anchor.addEventListener(\"click\", e => {\n          const href = anchor.getAttribute(\"href\");\n          if (href === \"#\") return;\n          e.preventDefault();\n          const target = document.querySelector(href);\n          if (target) {\n            target.scrollIntoView({\n              behavior: \"smooth\"\n            });\n          }\n        });\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","scrolled","activeFilter","activeFilterIndex","form","email","phone","message","filterTabs","usingNow","icon","learning","projects","image","type","featured","description","computed","filteredProjects","filter","p","filterUnderlineStyle","tabWidth","startOffset","width","left","mounted","window","addEventListener","handleScroll","setupSmoothScroll","beforeUnmount","removeEventListener","methods","scrollY","setFilter","tab","index","handleSubmit","alert","document","querySelectorAll","forEach","anchor","e","href","getAttribute","preventDefault","target","querySelector","scrollIntoView","behavior"],"sources":["C:\\Users\\Tunying\\Desktop\\eds\\PortfolioV1\\portfoliov1\\src\\views\\HomeView.vue"],"sourcesContent":["<template>\n  <div class=\"portfolio\">\n    <!-- Scrolled Navbar -->\n    <nav class=\"navbar-scrolled\" :class=\"{ show: scrolled }\">\n      <div class=\"container-fluid px-4 h-100\">\n        <div class=\"d-flex align-items-center justify-content-end h-100 gap-1\">\n          <a href=\"#about\" class=\"nav-link-custom\">About me</a>\n          <a href=\"#skills\" class=\"nav-link-custom\">Skills</a>\n          <a href=\"#portfolio\" class=\"nav-link-custom\">Portfolio</a>\n          <a href=\"#contact\" class=\"btn-contact\">CONTACT ME</a>\n        </div>\n      </div>\n    </nav>\n\n    <!-- Hero -->\n    <section id=\"hero\" class=\"hero-section\">\n      <div class=\"container position-relative\">\n        <img src=\"/assets/logo.svg\" alt=\"Logo\" class=\"hero-logo\" />\n\n        <nav class=\"hero-nav d-none d-lg-flex align-items-center\">\n          <a href=\"#about\" class=\"nav-link-custom\">About me</a>\n          <a href=\"#skills\" class=\"nav-link-custom\">Skills</a>\n          <a href=\"#portfolio\" class=\"nav-link-custom\">Portfolio</a>\n          <a href=\"#contact\" class=\"btn-contact\">CONTACT ME</a>\n        </nav>\n\n        <div class=\"row hero-content align-items-center\">\n          <div class=\"col-lg-6\">\n            <p class=\"hero-greeting\">Hi, I am</p>\n            <h1 class=\"hero-name\">Ed Rascoe Cagatan</h1>\n            <p class=\"hero-title\">Junior back-end Developer / UI Designer</p>\n            <div class=\"social-links mt-4\">\n              <a href=\"mailto:edcagatan00@gmail.com\" class=\"social-btn\" aria-label=\"Email\">\n                <img src=\"/assets/icon-mail.svg\" alt=\"Email\" />\n              </a>\n              <a href=\"#\" class=\"social-btn\" aria-label=\"GitHub\">\n                <img src=\"/assets/icon-github.svg\" alt=\"GitHub\" />\n              </a>\n              <a href=\"#\" class=\"social-btn\" aria-label=\"LinkedIn\">\n                <img src=\"/assets/icon-linkedin.svg\" alt=\"LinkedIn\" />\n              </a>\n            </div>\n          </div>\n          <div class=\"col-lg-6 hero-photo-wrap flex-column\">\n            <img src=\"/assets/hero-photo.png\" alt=\"Portrait\" class=\"hero-photo\" />\n            <p class=\"hero-photo-caption d-none d-lg-block\">\n              this is not my photo, but I dearly hope to get one just like this\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Summary -->\n    <section id=\"summary\" class=\"summary-section\">\n      <div class=\"summary-dark\">\n        <div class=\"container position-relative\">\n          <div class=\"it-logo d-none d-xl-flex\">\n            <span>IT</span>\n          </div>\n          <h2 class=\"summary-title\">Summary</h2>\n          <p class=\"summary-text\">\n            Detail-oriented and adaptable Information Technology student with hands-on\n            internship experience in backend development. Possesses a strong foundation in\n            database management, logic formulation, and technical problem-solving. Highly\n            teachable and eager to transition academic foundations and technical expertise\n            into a long-term role, whether in development or remote technical client\n            support. Fully equipped for permanent work-from-home operations with a reliable\n            internet setup and power backup.\n          </p>\n          <button type=\"button\" class=\"btn-outline-custom mt-4 text-white\">\n            READ MORE\n          </button>\n        </div>\n      </div>\n    </section>\n\n    <!-- About -->\n    <section id=\"about\" class=\"about-section text-center\">\n      <div class=\"container\">\n        <div class=\"section-title-box\">\n          <h2 class=\"section-title\">About Me</h2>\n        </div>\n        <p class=\"about-text\">\n          My name is Ed Rascoe Cagatan, I'm a Fourth year Information Technology student\n          at the Leyte Normal University in Tacloban City. I have been learning Front-End\n          and backend technologies for a year and this time was just enough for me to make\n          sure that this is my place in the industry.\n        </p>\n        <button type=\"button\" class=\"btn-outline-custom\">EXPLORE</button>\n        <div class=\"separator\"></div>\n\n        <div class=\"row g-4 services-row\">\n          <div class=\"col-md-6\">\n            <div class=\"service-card text-start\">\n              <div class=\"service-icon-placeholder mb-2\">✎</div>\n              <h3 class=\"service-title\">DESIGN</h3>\n              <p class=\"service-text\">\n                I can design the site based on your needs and suggestions. I can also\n                design the site from scratch and consult you during the job.\n              </p>\n            </div>\n          </div>\n          <div class=\"col-md-6\">\n            <div class=\"service-card text-start\">\n              <div class=\"service-icon-placeholder mb-2\">&lt;/&gt;</div>\n              <h3 class=\"service-title\">DEVELOPMENT</h3>\n              <p class=\"service-text\">\n                Based on a project created by me or another one, sent by you, I can program\n                the website to be fully functional and responsive.\n              </p>\n            </div>\n          </div>\n          <div class=\"col-12\">\n            <div class=\"service-card text-center mx-auto\" style=\"max-width: 500px\">\n              <div class=\"service-icon-placeholder mb-2\">⚙</div>\n              <h3 class=\"service-title\">MAINTENANCE</h3>\n              <p class=\"service-text\">\n                In case of any problems or the need for changes, I can introduce new\n                functionalities and solutions.\n              </p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"separator\"></div>\n\n        <!-- Skills -->\n        <div id=\"skills\" class=\"skills-section\">\n          <div class=\"section-title-box\">\n            <h2 class=\"section-title\">Skills</h2>\n          </div>\n\n          <h3 class=\"skills-subtitle text-start\">USING NOW:</h3>\n          <div class=\"row\">\n            <div v-for=\"skill in usingNow\" :key=\"skill.name\" class=\"col-6 col-md-3\">\n              <div class=\"skill-item\">\n                <img :src=\"skill.icon\" :alt=\"skill.name\" class=\"skill-icon\" />\n                <p class=\"skill-label\">{{ skill.name }}</p>\n              </div>\n            </div>\n          </div>\n\n          <h3 class=\"skills-subtitle text-start mt-5\">LEARNING:</h3>\n          <div class=\"row\">\n            <div v-for=\"skill in learning\" :key=\"skill.name\" class=\"col-6 col-md-3\">\n              <div class=\"skill-item\">\n                <img :src=\"skill.icon\" :alt=\"skill.name\" class=\"skill-icon\" />\n                <p class=\"skill-label\">{{ skill.name }}</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Portfolio -->\n    <section id=\"portfolio\" class=\"portfolio-section\">\n      <div class=\"portfolio-header\">\n        <img src=\"/assets/portfolio-header.jpg\" alt=\"Portfolio header\" />\n        <div class=\"portfolio-header-overlay\">\n          <div class=\"section-title-box\">\n            <h2 class=\"section-title\">Portfolio</h2>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"container-fluid px-0\">\n        <div class=\"filter-bar position-relative\">\n          <button\n            v-for=\"(tab, index) in filterTabs\"\n            :key=\"tab\"\n            type=\"button\"\n            class=\"filter-tab\"\n            :class=\"{ active: activeFilter === tab }\"\n            @click=\"setFilter(tab, index)\"\n          >\n            {{ tab }}\n          </button>\n          <div class=\"filter-underline\"></div>\n          <div\n            class=\"filter-underline-active\"\n            :style=\"filterUnderlineStyle\"\n          ></div>\n        </div>\n\n        <div class=\"row g-0 project-grid\">\n          <div\n            v-for=\"(project, index) in filteredProjects\"\n            :key=\"index\"\n            class=\"col-12 col-md-4\"\n          >\n            <div\n              class=\"project-item\"\n              :class=\"{ featured: project.featured }\"\n            >\n              <img :src=\"project.image\" :alt=\"project.name || 'Project'\" />\n              <div v-if=\"project.featured\" class=\"project-overlay\">\n                <span class=\"project-tag\">coded, designed</span>\n                <h3 class=\"project-name\">{{ project.name }}</h3>\n                <p class=\"project-desc\">{{ project.description }}</p>\n                <div class=\"project-links\">\n                  <a href=\"#\" class=\"project-link\">DEMO</a>\n                  <a href=\"#\" class=\"project-link\">MORE</a>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <p class=\"portfolio-footer-text\">And many more to come!</p>\n      </div>\n    </section>\n\n    <!-- Contact -->\n    <section id=\"contact\" class=\"contact-section text-center\">\n      <div class=\"container\">\n        <div class=\"section-title-box\">\n          <h2 class=\"section-title\">Contact</h2>\n        </div>\n        <p class=\"contact-intro\">\n          Nulla in velit a metus rhoncus tempus. Nulla congue nulla vel sem varius\n          finibus. Sed ornare sit amet lorem sed viverra. In vel urna quis libero\n          viverra facilisis ut ac est.\n        </p>\n\n        <form class=\"contact-form text-start\" @submit.prevent=\"handleSubmit\">\n          <div class=\"form-field\">\n            <input\n              v-model=\"form.name\"\n              type=\"text\"\n              placeholder=\"Ed Rascoe Cagatan\"\n              aria-label=\"Name\"\n            />\n          </div>\n          <div class=\"form-field\">\n            <input\n              v-model=\"form.email\"\n              type=\"email\"\n              placeholder=\"edcagatan00@gmail.com\"\n              aria-label=\"Email\"\n            />\n          </div>\n          <div class=\"form-field\">\n            <input\n              v-model=\"form.phone\"\n              type=\"tel\"\n              placeholder=\"09855695788\"\n              aria-label=\"Phone\"\n            />\n          </div>\n          <div class=\"form-field message-field\">\n            <textarea\n              v-model=\"form.message\"\n              placeholder=\"YOUR MESSAGE*\"\n              aria-label=\"Message\"\n            ></textarea>\n          </div>\n          <button type=\"submit\" class=\"btn-submit\">SUBMIT</button>\n        </form>\n      </div>\n    </section>\n\n    <!-- Footer -->\n    <footer class=\"footer-section\">\n      <a href=\"#hero\" class=\"back-to-top\">\n        ↑ BACK TO TOP\n      </a>\n      <div class=\"footer-social\">\n        <a href=\"mailto:edcagatan00@gmail.com\" aria-label=\"Email\">@</a>\n        <a href=\"#\" aria-label=\"GitHub\">GH</a>\n        <a href=\"#\" aria-label=\"LinkedIn\">in</a>\n        <a href=\"#\" aria-label=\"Twitter\">X</a>\n      </div>\n      <p class=\"footer-copy\">\n        @2026 Ed Rascoe Cagatan All Rights Reserved.\n      </p>\n    </footer>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"HomeView\",\n  data() {\n    return {\n      scrolled: false,\n      activeFilter: \"ALL\",\n      activeFilterIndex: 0,\n      form: {\n        name: \"\",\n        email: \"\",\n        phone: \"\",\n        message: \"\",\n      },\n      filterTabs: [\"ALL\", \"CODED\", \"DESIGNED\"],\n      usingNow: [\n        {\n          name: \"HTML5\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg\",\n        },\n        {\n          name: \"CSS3\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg\",\n        },\n        {\n          name: \"SASS\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sass/sass-original.svg\",\n        },\n        {\n          name: \"JAVASCRIPT\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg\",\n        },\n        {\n          name: \"REACT\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg\",\n        },\n        {\n          name: \"BOOTSTRAP\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bootstrap/bootstrap-original.svg\",\n        },\n        {\n          name: \"GIT\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg\",\n        },\n        {\n          name: \"FIGMA\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg\",\n        },\n      ],\n      learning: [\n        {\n          name: \"NODEJS\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg\",\n        },\n        {\n          name: \"MySQL\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg\",\n        },\n        {\n          name: \"MONGODB\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mongodb/mongodb-original.svg\",\n        },\n        {\n          name: \"TYPESCRIPT\",\n          icon: \"https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg\",\n        },\n      ],\n      projects: [\n        { image: \"/assets/project-1.jpg\", type: \"DESIGNED\" },\n        {\n          image: \"/assets/project-3.jpg\",\n          type: \"CODED\",\n          featured: true,\n          name: \"eatsome.\",\n          description: \"Restaurant browsing in React.js (Using Yelp API)\",\n        },\n        { image: \"/assets/project-2.jpg\", type: \"DESIGNED\" },\n        { image: \"/assets/project-1.jpg\", type: \"CODED\" },\n        { image: \"/assets/project-2.jpg\", type: \"DESIGNED\" },\n        { image: \"/assets/project-1.jpg\", type: \"CODED\" },\n      ],\n    };\n  },\n  computed: {\n    filteredProjects() {\n      if (this.activeFilter === \"ALL\") return this.projects;\n      return this.projects.filter((p) => p.type === this.activeFilter);\n    },\n    filterUnderlineStyle() {\n      const tabWidth = 149;\n      const startOffset = (587 - tabWidth * 3) / 2;\n      return {\n        width: `${tabWidth}px`,\n        left: `calc(50% - 293px + ${startOffset + this.activeFilterIndex * tabWidth}px)`,\n      };\n    },\n  },\n  mounted() {\n    window.addEventListener(\"scroll\", this.handleScroll);\n    this.setupSmoothScroll();\n  },\n  beforeUnmount() {\n    window.removeEventListener(\"scroll\", this.handleScroll);\n  },\n  methods: {\n    handleScroll() {\n      this.scrolled = window.scrollY > 400;\n    },\n    setFilter(tab, index) {\n      this.activeFilter = tab;\n      this.activeFilterIndex = index;\n    },\n    handleSubmit() {\n      alert(\"Thank you for your message! I will get back to you soon.\");\n      this.form = { name: \"\", email: \"\", phone: \"\", message: \"\" };\n    },\n    setupSmoothScroll() {\n      document.querySelectorAll('a[href^=\"#\"]').forEach((anchor) => {\n        anchor.addEventListener(\"click\", (e) => {\n          const href = anchor.getAttribute(\"href\");\n          if (href === \"#\") return;\n          e.preventDefault();\n          const target = document.querySelector(href);\n          if (target) {\n            target.scrollIntoView({ behavior: \"smooth\" });\n          }\n        });\n      });\n    },\n  },\n};\n</script>\n\n<style scoped>\n.service-icon-placeholder {\n  font-size: 2.5rem;\n  opacity: 0.15;\n  line-height: 1;\n}\n</style>\n"],"mappings":";;;AA0RA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,KAAK;MACfC,YAAY,EAAE,KAAK;MACnBC,iBAAiB,EAAE,CAAC;MACpBC,IAAI,EAAE;QACJL,IAAI,EAAE,EAAE;QACRM,KAAK,EAAE,EAAE;QACTC,KAAK,EAAE,EAAE;QACTC,OAAO,EAAE;MACX,CAAC;MACDC,UAAU,EAAE,CAAC,KAAK,EAAE,OAAO,EAAE,UAAU,CAAC;MACxCC,QAAQ,EAAE,CACR;QACEV,IAAI,EAAE,OAAO;QACbW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,MAAM;QACZW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,MAAM;QACZW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,YAAY;QAClBW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,OAAO;QACbW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,WAAW;QACjBW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,KAAK;QACXW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,OAAO;QACbW,IAAI,EAAE;MACR,CAAC,CACF;MACDC,QAAQ,EAAE,CACR;QACEZ,IAAI,EAAE,QAAQ;QACdW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,OAAO;QACbW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,SAAS;QACfW,IAAI,EAAE;MACR,CAAC,EACD;QACEX,IAAI,EAAE,YAAY;QAClBW,IAAI,EAAE;MACR,CAAC,CACF;MACDE,QAAQ,EAAE,CACR;QAAEC,KAAK,EAAE,uBAAuB;QAAEC,IAAI,EAAE;MAAW,CAA